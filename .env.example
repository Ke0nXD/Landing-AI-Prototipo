# Public app metadata
NEXT_PUBLIC_APP_URL=http://localhost:3000

# AI provider selection
# mock = local deterministic generator
# anthropic = Claude Messages API, server-side only
AI_DEFAULT_PROVIDER=mock

# Anthropic Claude server-side integration
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# Supabase server-side integration (optional while local mock is active)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Future Hugging Face server-side integration
# Never expose this as NEXT_PUBLIC_*.
HF_API_TOKEN=
HF_TEXT_MODEL=
HF_CLASSIFICATION_MODEL=
